SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=
REMINDERS_ENABLED=true #false để tắt thông báo
# Người theo dõi: nhận DM mọi bước 'Đã xong'/'Bỏ qua' (ngoài trưởng phòng của bước đó).
# Điền open_id lấy từ cột open_id bảng pic_members, nhiều người cách nhau dấu phẩy.
STEP_DONE_WATCHER_OPEN_IDS=

# Auth
JWT_SECRET=doi-thanh-chuoi-ngau-nhien-dai
JWT_EXPIRES_IN=7d
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Chỉ cho phép email domain này đăng nhập (vd: ozovn.com). Để trống = cho tất cả.
ALLOWED_EMAIL_DOMAIN=
# Mã bí mật chung để PIC nâng quyền lên Quản lý (sửa tất cả). ĐỔI thành chuỗi khó đoán.
MANAGER_CODE=
# (Ai là PIC được quản lý trong bảng public.pic_members trên Supabase — không cấu hình ở đây.)

# === Gửi mã OTP qua email (HTTP API — chạy được trên Render/Vercel) ===
# Backend ưu tiên: Brevo > SendGrid > Resend > SMTP.
# MAIL_FROM = người gửi, PHẢI là email đã verify ở dịch vụ đang dùng.
MAIL_FROM=

# Cách KHUYẾN NGHỊ: Brevo — verify 1 email người gửi, KHÔNG cần DNS.
BREVO_API_KEY=

LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFY_TOKEN=
# Lark quốc tế: https://open.larksuite.com | Feishu (TQ): https://open.feishu.cn
LARK_BASE_URL=https://open.larksuite.com

# === Cloudinary (lưu ảnh/file đính kèm) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GROQ_API_KEY=
GROQ_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
LLM_PROVIDER=gemini #hoặc groq

#Không cần set LARK_REPORT_CHAT_ID — bot tự gửi vào nhóm nó tham gia. Nếu sau này bot vào nhiều nhóm mà chỉ muốn báo cáo 1 nhóm, thì set env đó = oc_6fbd0cbb210b2115bfcaaf401ad4da16.